# ─────────────────────────────────────────────────────────────────────────────
# playermap-web: public environment variables
#
# All variables are PUBLIC (NEXT_PUBLIC_*) and OPTIONAL: the site builds and runs
# without them. Copy this file to `.env.local` for local overrides, and set the
# same variables in your deployment environment (Vercel, etc.) for production.
# ─────────────────────────────────────────────────────────────────────────────

# Canonical site URL.
# ⚠️ ACTION REQUIRED in production: set this to the real deployed domain so that
# Open Graph / Twitter social-share images and canonical links resolve to
# ABSOLUTE URLs. If unset, it falls back to https://playermap.box.
NEXT_PUBLIC_SITE_URL=https://playermap.box

# Target of the "Launch app" button (the live player-graph application).
# If unset, falls back to the default below.
NEXT_PUBLIC_APP_URL=https://playermap.box/test-player-map/index.html
